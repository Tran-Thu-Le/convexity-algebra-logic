sum(x,y) = sum(y,x).
sum(x,es) = x.

% --- Semiring (SM1-SM2) ---
sum(x,meet(y,z)) = meet(sum(x,y),sum(x,z)).
sum(x,em) = em.

% --- Polar (P, PM) ---
star(star(x)) = x.
meet(x,y) = x <-> meet(star(y),star(x)) = star(y).

% --- Derived operation definitions ---
join(x,y) = star(meet(star(x),star(y))).
mult(x,y) = star(sum(star(x),star(y))).
ej = star(em).
ex = star(es).

end_of_list.

formulas(goals).
meet(ej,x) = ej.
end_of_list.

% ==== Theorem 14: monotonicity of meet ====
% ===== PICS: Polar Idempotent Commutative Semiring =====
% meet(x,y)  = a ^ b
% sum(x,y)   = a + b
% star(x)    = a*
% em         = e_meet   (identity/top for meet)
% es         = e_sum    (identity for sum)
% join(x,y)  = a v b     (derived)
% mult(x,y)  = a x b     (derived)
% ej, ex     = e_join, e_mult (derived)

formulas(assumptions).

% --- Meet (M0-M3) ---
meet(x,x) = x.
meet(meet(x,y),z) = meet(x,meet(y,z)).
meet(x,y) = meet(y,x).
meet(x,em) = x.

% --- Sum (S1-S3) ---
sum(sum(x,y),z) = sum(x,sum(y,z)).
sum(x,y) = sum(y,x).
sum(x,es) = x.

% --- Semiring (SM1-SM2) ---
sum(x,meet(y,z)) = meet(sum(x,y),sum(x,z)).
sum(x,em) = em.

% --- Polar (P, PM) ---
star(star(x)) = x.
meet(x,y) = x <-> meet(star(y),star(x)) = star(y).

% --- Derived operation definitions ---
join(x,y) = star(meet(star(x),star(y))).
mult(x,y) = star(sum(star(x),star(y))).
ej = star(em).
ex = star(es).

end_of_list.

formulas(goals).
meet(x,y) = x -> meet(meet(x,z),meet(y,z)) = meet(x,z).
end_of_list.

% ==== Theorem 15: monotonicity of sum ====
% ===== PICS: Polar Idempotent Commutative Semiring =====
% meet(x,y)  = a ^ b
% sum(x,y)   = a + b
% star(x)    = a*
% em         = e_meet   (identity/top for meet)
% es         = e_sum    (identity for sum)
% join(x,y)  = a v b     (derived)
% mult(x,y)  = a x b     (derived)
% ej, ex     = e_join, e_mult (derived)

formulas(assumptions).

% --- Meet (M0-M3) ---
meet(x,x) = x.
meet(meet(x,y),z) = meet(x,meet(y,z)).
meet(x,y) = meet(y,x).
meet(x,em) = x.

% --- Sum (S1-S3) ---
sum(sum(x,y),z) = sum(x,sum(y,z)).
sum(x,y) = sum(y,x).
sum(x,es) = x.

% --- Semiring (SM1-SM2) ---
sum(x,meet(y,z)) = meet(sum(x,y),sum(x,z)).
sum(x,em) = em.

% --- Polar (P, PM) ---
star(star(x)) = x.
meet(x,y) = x <-> meet(star(y),star(x)) = star(y).

% --- Derived operation definitions ---
join(x,y) = star(meet(star(x),star(y))).
mult(x,y) = star(sum(star(x),star(y))).
ej = star(em).
ex = star(es).

end_of_list.

formulas(goals).
meet(x,y) = x -> meet(sum(x,z),sum(y,z)) = sum(x,z).
end_of_list.

% ==== Theorem 16: order reversal: a<=b iff b*<=a* ====
% ===== PICS: Polar Idempotent Commutative Semiring =====
% meet(x,y)  = a ^ b
% sum(x,y)   = a + b
% star(x)    = a*
% em         = e_meet   (identity/top for meet)
% es         = e_sum    (identity for sum)
% join(x,y)  = a v b     (derived)
% mult(x,y)  = a x b     (derived)
% ej, ex     = e_join, e_mult (derived)

formulas(assumptions).

% --- Meet (M0-M3) ---
meet(x,x) = x.
meet(meet(x,y),z) = meet(x,meet(y,z)).
meet(x,y) = meet(y,x).
meet(x,em) = x.

% --- Sum (S1-S3) ---
sum(sum(x,y),z) = sum(x,sum(y,z)).
sum(x,y) = sum(y,x).
sum(x,es) = x.

% --- Semiring (SM1-SM2) ---
sum(x,meet(y,z)) = meet(sum(x,y),sum(x,z)).
sum(x,em) = em.

% --- Polar (P, PM) ---
star(star(x)) = x.
meet(x,y) = x <-> meet(star(y),star(x)) = star(y).

% --- Derived operation definitions ---
join(x,y) = star(meet(star(x),star(y))).
mult(x,y) = star(sum(star(x),star(y))).
ej = star(em).
ex = star(es).

end_of_list.

formulas(goals).
meet(x,y) = x <-> meet(star(y),star(x)) = star(y).
end_of_list.

% ==== Theorem 17: <=v is a partial order (reflexive is Thm6; antisymmetric; transitive) ====
% ===== PICS: Polar Idempotent Commutative Semiring =====
% meet(x,y)  = a ^ b
% sum(x,y)   = a + b
% star(x)    = a*
% em         = e_meet   (identity/top for meet)
% es         = e_sum    (identity for sum)
% join(x,y)  = a v b     (derived)
% mult(x,y)  = a x b     (derived)
% ej, ex     = e_join, e_mult (derived)

formulas(assumptions).

% --- Meet (M0-M3) ---
meet(x,x) = x.
meet(meet(x,y),z) = meet(x,meet(y,z)).
meet(x,y) = meet(y,x).
meet(x,em) = x.

% --- Sum (S1-S3) ---
sum(sum(x,y),z) = sum(x,sum(y,z)).
sum(x,y) = sum(y,x).
sum(x,es) = x.

% --- Semiring (SM1-SM2) ---
sum(x,meet(y,z)) = meet(sum(x,y),sum(x,z)).
sum(x,em) = em.

% --- Polar (P, PM) ---
star(star(x)) = x.
meet(x,y) = x <-> meet(star(y),star(x)) = star(y).

% --- Derived operation definitions ---
join(x,y) = star(meet(star(x),star(y))).
mult(x,y) = star(sum(star(x),star(y))).
ej = star(em).
ex = star(es).

end_of_list.

formulas(goals).
join(x,x) = x & ((join(x,y) = y & join(y,x) = x) -> x = y) & ((join(x,y) = y & join(y,z) = z) -> join(x,z) = z).
end_of_list.

% ==== Theorem 18: a v b is the supremum of a,b w.r.t. <= ====
% ===== PICS: Polar Idempotent Commutative Semiring =====
% meet(x,y)  = a ^ b
% sum(x,y)   = a + b
% star(x)    = a*
% em         = e_meet   (identity/top for meet)
% es         = e_sum    (identity for sum)
% join(x,y)  = a v b     (derived)
% mult(x,y)  = a x b     (derived)
% ej, ex     = e_join, e_mult (derived)

formulas(assumptions).

% --- Meet (M0-M3) ---
meet(x,x) = x.
meet(meet(x,y),z) = meet(x,meet(y,z)).
meet(x,y) = meet(y,x).
meet(x,em) = x.

% --- Sum (S1-S3) ---
sum(sum(x,y),z) = sum(x,sum(y,z)).
sum(x,y) = sum(y,x).
sum(x,es) = x.

% --- Semiring (SM1-SM2) ---
sum(x,meet(y,z)) = meet(sum(x,y),sum(x,z)).
sum(x,em) = em.

% --- Polar (P, PM) ---
star(star(x)) = x.
meet(x,y) = x <-> meet(star(y),star(x)) = star(y).

% --- Derived operation definitions ---
join(x,y) = star(meet(star(x),star(y))).
mult(x,y) = star(sum(star(x),star(y))).
ej = star(em).
ex = star(es).

end_of_list.

formulas(goals).
meet(x,join(x,y)) = x & meet(y,join(x,y)) = y & ((meet(x,z) = x & meet(y,z) = y) -> meet(join(x,y),z) = join(x,y)).
end_of_list.

% ==== Theorem 19: the two induced orders coincide: <= = <=v ====
% ===== PICS: Polar Idempotent Commutative Semiring =====
% meet(x,y)  = a ^ b
% sum(x,y)   = a + b
% star(x)    = a*
% em         = e_meet   (identity/top for meet)
% es         = e_sum    (identity for sum)
% join(x,y)  = a v b     (derived)
% mult(x,y)  = a x b     (derived)
% ej, ex     = e_join, e_mult (derived)

formulas(assumptions).

% --- Meet (M0-M3) ---
meet(x,x) = x.
meet(meet(x,y),z) = meet(x,meet(y,z)).
meet(x,y) = meet(y,x).
meet(x,em) = x.

% --- Sum (S1-S3) ---
sum(sum(x,y),z) = sum(x,sum(y,z)).
sum(x,y) = sum(y,x).
sum(x,es) = x.

% --- Semiring (SM1-SM2) ---
sum(x,meet(y,z)) = meet(sum(x,y),sum(x,z)).
sum(x,em) = em.

% --- Polar (P, PM) ---
star(star(x)) = x.
meet(x,y) = x <-> meet(star(y),star(x)) = star(y).

% --- Derived operation definitions ---
join(x,y) = star(meet(star(x),star(y))).
mult(x,y) = star(sum(star(x),star(y))).
ej = star(em).
ex = star(es).

end_of_list.

formulas(goals).
meet(x,y) = x <-> join(x,y) = y.
end_of_list.

% ==== Theorem 20: absorption laws ====
% ===== PICS: Polar Idempotent Commutative Semiring =====
% meet(x,y)  = a ^ b
% sum(x,y)   = a + b
% star(x)    = a*
% em         = e_meet   (identity/top for meet)
% es         = e_sum    (identity for sum)
% join(x,y)  = a v b     (derived)
% mult(x,y)  = a x b     (derived)
% ej, ex     = e_join, e_mult (derived)

formulas(assumptions).

% --- Meet (M0-M3) ---
meet(x,x) = x.
meet(meet(x,y),z) = meet(x,meet(y,z)).
meet(x,y) = meet(y,x).
meet(x,em) = x.

% --- Sum (S1-S3) ---
sum(sum(x,y),z) = sum(x,sum(y,z)).
sum(x,y) = sum(y,x).
sum(x,es) = x.

% --- Semiring (SM1-SM2) ---
sum(x,meet(y,z)) = meet(sum(x,y),sum(x,z)).
sum(x,em) = em.

% --- Polar (P, PM) ---
star(star(x)) = x.
meet(x,y) = x <-> meet(star(y),star(x)) = star(y).

% --- Derived operation definitions ---
join(x,y) = star(meet(star(x),star(y))).
mult(x,y) = star(sum(star(x),star(y))).
ej = star(em).
ex = star(es).

end_of_list.

formulas(goals).
meet(x,join(x,y)) = x & join(x,meet(x,y)) = x.
end_of_list.
